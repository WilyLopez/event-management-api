# ============================================================
# Copia este archivo como .env y rellena cada valor.
# NUNCA subas el .env al repositorio.
# ============================================================

# ============================================================
# BASE DE DATOS
# ============================================================
DB_URL=jdbc:postgresql://localhost:5432/nombre_base_datos
DB_USERNAME=postgres
DB_PASSWORD=tu_password_aqui

# ============================================================
# CORREO (Gmail SMTP)
# Para MAIL_PASSWORD usa una "Contrasena de aplicacion" de Google,
# no tu contrasena normal.
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_SENDER_NAME=Kiki y Lala

# ============================================================
# APLICACION
# ============================================================
SERVER_PORT=8080
APP_URL=http://localhost:8080

# ============================================================
# SEGURIDAD JWT
# JWT_SECRET debe ser una cadena aleatoria larga y segura.
# ============================================================
JWT_SECRET=genera_una_cadena_aleatoria_de_al_menos_32_caracteres
JWT_EXP_MS=1800000
JWT_VER_EXP_MS=86400000

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# ALMACENAMIENTO (Supabase Storage - S3 compatible)
# Las credenciales se obtienen en Supabase Dashboard > Storage > S3 Connection
# ============================================================
SUPABASE_STORAGE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_STORAGE_ACCESS_KEY=tu_access_key_id
SUPABASE_STORAGE_SECRET_KEY=tu_secret_access_key
SUPABASE_STORAGE_REGION=us-east-2
SUPABASE_STORAGE_URL_PUBLICA=https://<project-ref>.supabase.co/storage/v1/object/public

# ============================================================
# SUNAT / NUBEFACT
# ============================================================
NUBEFACT_URL=https://api.nubefact.com
NUBEFACT_TOKEN=tu_token_nubefact
NUBEFACT_RUC=tu_ruc_empresa

# ============================================================
# DECOLECTA API
# ============================================================
DECOLECTA_URL=https://api.decolecta.com
DECOLECTA_TOKEN=tu_token_decolecta

# ============================================================
# CIFRADO
# ============================================================
ENCRYPTION_KEY=tu_clave_de_cifrado_aes_16_24_32_bytes
